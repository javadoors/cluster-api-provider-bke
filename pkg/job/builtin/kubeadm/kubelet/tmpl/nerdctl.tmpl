nerdctl -n k8s.io --insecure-registry run -d --name {{ .containerName }} --net=host --pid host --user=root  --privileged  --restart=always \
-v /var/lib/openFuyao/etcd:/var/lib/openFuyao/etcd \
-v /etc/kubernetes/:/etc/kubernetes/ \
-v /etc/localtime:/etc/localtime \
-v /etc/ssl/certs:/etc/ssl/certs \
-v /etc/sysconfig/network-scripts:/etc/sysconfig/network-scripts \
-v /etc/resolv.conf:/etc/resolv.conf \
-v /run:/run \
-v /var/run:/var/run:rw \
-v /sys:/sys \
-v /proc:/proc \
-v /dev:/dev \
-v /lib/modules:/lib/modules \
-v /usr/libexec/kubernetes:/usr/libexec/kubernetes \
-v /var/lib/docker:/var/lib/docker:rw,rslave \
-v /var/lib/kubelet:/var/lib/kubelet:shared \
-v /var/lib/calico:/var/lib/calico \
-v /var/lib/cni:/var/lib/cni \
-v /var/lib/lxc:/var/lib/lxc \
-v /var/log/pods:/var/log/pods \
-v /var/lib/containerd:/var/lib/containerd \
-v /var/log/containers:/var/log/containers \
-v /etc/cni:/etc/cni:rw \
-v /opt/cni:/opt/cni:rw \
-v /opt/fabric:/opt/fabric \
{{ if ne .extraVolumes "" }}
    {{- .extraVolumes }} \
{{- end }}
{{ .kubeletImage }} \
kubelet \
--v=0 \
{{- if ne .extraArgs ""  }}
    {{- .extraArgs }} \
{{- end }}
--kubeconfig={{ .kubeconfigPath }} \
--config=/var/lib/kubelet/config.yaml \
--hostname-override={{ .hostName }} \
--node-ip={{ .hostIP }} \
{{- if eq .kubernetesVersion "v1.21.1" }}
--network-plugin=cni \
--cni-conf-dir=/etc/cni/net.d \
--cni-bin-dir=/opt/cni/bin \
{{- end }}
{{- if ne .kubernetesVersion "v1.27.1" }}
--pod-infra-container-image={{ .pauseImage }} \
{{- end }}
--container-runtime=remote \
--container-runtime-endpoint=unix:///run/containerd/containerd.sock \


